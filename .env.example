# MISTRAL AI
MISTRAL_API_KEY=your_mistral_api_key_here

# SUPABASE POSTGRESQL
# Connection string aus Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Serverless DB pool tuning (recommended for Vercel/Lambda)
DB_POOL_MAX=1
DB_POOL_IDLE_TIMEOUT_MS=10000
DB_POOL_CONN_TIMEOUT_MS=10000
# Set only for local/dev bootstrap. Keep false in production.
DB_SCHEMA_INIT_ON_START=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# REDIS CACHE (Vercel / Upstash)
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# MICROSOFT TEAMS INTEGRATION
# 1. Erstelle eine App in https://portal.azure.com → Azure Active Directory → App-Registrierungen
# 2. Füge die Berechtigung 'OnlineMeetings.ReadWrite' (delegiert) hinzu
# 3. Produktion Redirect-URI: https://your-app.vercel.app/api/teams/callback
# 4. Lokal Redirect-URI: http://localhost:3001/api/teams/callback
MICROSOFT_CLIENT_ID=your_azure_app_client_id
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/teams/callback
FRONTEND_URL=http://localhost:5173

# E-MAIL (Nodemailer SMTP – IONOS/1&1)
# WICHTIG: smtp-1and1.live.any.po.server.lan ist ein internes .lan-Hostname → nur im IONOS-Netz erreichbar
# Von Vercel (extern) IMMER den öffentlichen Host verwenden:
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=mp1058595367-1777316983617
SMTP_PASS=dein_email_passwort
APP_BASE_URL=https://beequ.de

# SERVER (nur lokale Entwicklung)
PORT=3001
NODE_ENV=development

# FRONTEND
VITE_API_URL=http://localhost:3001/api