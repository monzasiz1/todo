{
  "appId": "com.beequ.app",
  "appName": "BeeQu",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "url": "https://www.beequ.de/app",
    "cleartext": false,
    "allowNavigation": [
      "www.beequ.de",
      "beequ.de",
      "*.beequ.de"
    ]
  },
  "android": {
    "backgroundColor": "#0B1220",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "ios": {
    "backgroundColor": "#0B1220",
    "contentInset": "always"
  }
}
