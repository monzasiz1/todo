{
  "name": "beequ-desktop",
  "version": "1.0.11",
  "description": "BeeQu – Dein intelligenter Planer",
  "main": "main.js",
  "private": true,
  "author": {
    "name": "BeeQu",
    "email": "support@beequ.de"
  },
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:win:all": "electron-builder --win --x64 --ia32",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:all": "electron-builder --win --mac --x64",
    "release": "electron-builder --win --x64 --publish always",
    "release:draft": "electron-builder --win --x64 --publish onTagOrDraft"
  },
  "build": {
    "appId": "de.beequ.app",
    "productName": "BeeQu",
    "copyright": "Copyright © 2026 BeeQu",
    "icon": "icon.png",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "monzasiz1",
        "repo": "todo",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "icon.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "publisherName": "BeeQu",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "type": "distribution"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BeeQu",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "title": "BeeQu Installer",
      "backgroundColor": "#030812",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
